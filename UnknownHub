local function SetToggleVisual(btn, stroke, active)
    if active then
        btn.TextColor3  = Color3.new(1, 1, 1)
        stroke.Color    = Color3.new(0.34, 1, 0.34)
    else
        btn.TextColor3  = COLOR_TEXT_DIM
