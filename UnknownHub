    end
end

local function BindToggle(btn, stroke, name, handler)
    btn.MouseButton1Click:Connect(function()
        toggleStates[name] = not toggleStates[name]
        SetToggleVisual(btn, stroke, toggleStates[name])
        handler(toggleStates[name])
    end)
end

