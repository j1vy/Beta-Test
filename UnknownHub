-- ── Bat aimbot activation button (click L) ───────────────────────────────────
BatAimbotBtn.MouseButton1Click:Connect(function()
    -- Finds closest enemy and snaps camera/aim toward them
    local hrp = GetHRP(LocalPlayer)
    if not hrp then return end
    local closest, closestDist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local ohrp = GetHRP(plr)
            if ohrp then
                local dist = (ohrp.Position - hrp.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = ohrp
                end
            end
        end
    end
    if closest then
        hrp.CFrame = CFrame.new(hrp.Position, closest.Position)
        AimRing.Adornee = closest
        AimRing.Visible = true
    end
end)

