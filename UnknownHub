--[ Helper: Find local player's plot ]--
local function GetLocalPlot()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for _, plot in ipairs(plots:GetChildren()) do
        local sign = plot:FindFirstChild("PlotSign")
        if sign then
            local base = sign:FindFirstChild("YourBase")
            if base and base.Enabled then
                return plot
            end
        end
    end
    return nil
end

--[ Helper: Get a player's HumanoidRootPart safely ]--
local function GetHRP(player)
    local char = player and player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

--[ Helper: Get a player's Humanoid safely ]--
